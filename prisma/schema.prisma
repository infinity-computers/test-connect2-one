generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model users {
  id            String          @id @db.VarChar(64)
  name          String          @db.VarChar(100)
  email         String          @unique(map: "uk_users_email") @db.VarChar(150)
  phone         String?         @unique(map: "uk_users_phone") @db.VarChar(20)
  password      String?         @db.VarChar(255)
  plan_id       Int?
  expiry_date   DateTime?       @db.DateTime(0)
  duration      Int?
  role          ROLE?           @default(USER)
  auth_type     users_auth_type @default(PASSWORD)
  complaints    complaints[]
  payments      payments[]
  subscriptions subscriptions[]
}

model complaints {
  id                   Int                   @id @default(autoincrement())
  user_id              String                @db.VarChar(64)
  issue_type           complaints_issue_type
  explicit_description String?               @db.Text
  status               complaints_status?    @default(OPEN)
  created_at           DateTime              @default(now()) @db.Timestamp(0)
  users                users                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_complaint_user")

  @@index([user_id], map: "fk_complaint_user")
}

model payments {
  id                  String           @id @db.VarChar(36)
  subscription_id     String           @db.VarChar(36)
  user_id             String           @db.VarChar(64)
  amount              Decimal          @db.Decimal(10, 2)
  razorpay_payment_id String?          @db.VarChar(100)
  status              payments_status? @default(pending)
  payment_date        DateTime?        @db.DateTime(0)
  created_at          DateTime?        @default(now()) @db.Timestamp(0)
  updated_at          DateTime?        @default(now()) @db.Timestamp(0)
  subscriptions       subscriptions    @relation(fields: [subscription_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "payments_ibfk_1")
  users               users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "payments_ibfk_2")

  @@index([payment_date], map: "idx_payment_date")
  @@index([razorpay_payment_id], map: "idx_razorpay_id")
  @@index([status], map: "idx_status")
  @@index([subscription_id], map: "idx_subscription_id")
  @@index([user_id], map: "idx_user_id")
  @@index([user_id, status], map: "idx_user_status")
}

model plan_variants {
  id              String          @id @db.VarChar(36)
  plan_id         String          @db.VarChar(36)
  speed_mbps      Int
  duration_months Int
  price           Decimal         @db.Decimal(10, 2)
  created_at      DateTime?       @default(now()) @db.Timestamp(0)
  plans           plans           @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "plan_variants_ibfk_1")
  subscriptions   subscriptions[]

  @@unique([plan_id, speed_mbps, duration_months], map: "unique_variant")
  @@index([plan_id], map: "idx_plan_id")
  @@index([speed_mbps, duration_months], map: "idx_speed_duration")
}

model plans {
  id            String          @id @db.VarChar(36)
  name          String          @db.VarChar(50)
  description   String?         @db.Text
  created_at    DateTime?       @default(now()) @db.Timestamp(0)
  plan_variants plan_variants[]

  @@index([name], map: "idx_name")
}

model subscriptions {
  id              String                @id @db.VarChar(36)
  user_id         String                @db.VarChar(64)
  plan_variant_id String                @db.VarChar(36)
  start_date      DateTime              @db.Date
  end_date        DateTime              @db.Date
  status          subscriptions_status? @default(active)
  created_at      DateTime?             @default(now()) @db.Timestamp(0)
  updated_at      DateTime?             @default(now()) @db.Timestamp(0)
  payments        payments[]
  users           users                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "subscriptions_ibfk_1")
  plan_variants   plan_variants         @relation(fields: [plan_variant_id], references: [id], onUpdate: Restrict, map: "subscriptions_ibfk_2")

  @@index([end_date], map: "idx_end_date")
  @@index([status], map: "idx_status")
  @@index([user_id, status, end_date], map: "idx_user_active")
  @@index([user_id], map: "idx_user_id")
  @@index([user_id, status], map: "idx_user_status")
  @@index([plan_variant_id], map: "plan_variant_id")
}

enum ROLE {
  USER
  ADMIN
  TECHNICIAN
}

enum complaints_issue_type {
  Internet_speed                 @map("Internet speed")
  Downtime_outage                @map("Downtime/outage")
  Billing_error                  @map("Billing error")
  Equipment_fault                @map("Equipment fault")
  New_connection_delay           @map("New connection delay")
  Poor_signal                    @map("Poor signal")
  Not_working_more_than_4_hours  @map("Not working more than 4 hours")
  Not_working_more_than_24_hours @map("Not working more than 24 hours")
  Not_working_more_than_48_hours @map("Not working more than 48 hours")
  Other
}

enum complaints_status {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum payments_status {
  pending
  success
  failed
}

enum subscriptions_status {
  active
  expired
  cancelled
}

enum users_auth_type {
  PASSWORD
  OTP
}
