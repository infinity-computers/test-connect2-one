generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model users {
  id                               String                     @id @default(uuid())
  name                             String?
  email                            String?
  phone                            String?
  password                         String?
  role                             ROLE                       @default(USER)
  auth_type                        users_auth_type            @default(PASSWORD)
  status                           String?
  created_at                       DateTime?                  @default(now())
  updated_at                       DateTime?                  @default(now())
  tickets                          tickets[]                  @relation("UserTickets")
  assigned_tickets                 tickets[]                  @relation("TechnicianAssignments")
  otp_challenges                   otp_challenges[]
  payments                         payments[]
  subscriptions                    subscriptions[]
  new_connection_requests          new_connection_requests[]
  reviewed_new_connection_requests new_connection_requests[] @relation("NewConnectionRequestReviewer")
  created_document_upload_requests document_upload_requests[] @relation("DocumentUploadRequestCreator")
  uploaded_document_files          document_upload_files[]    @relation("DocumentUploadFileUploader")

  @@index([role], map: "idx_users_role")
}

model tickets {
  id                     String                   @id @default(uuid())
  user_id                String?
  assigned_technician_id String?
  source                 ticket_source            @default(AUTHENTICATED)
  reporter_name          String?
  reporter_phone         String?
  reporter_email         String?
  reporter_address       String?
  issue_type             ticket_issue_type
  explicit_description   String?
  status                 ticket_status            @default(PENDING_APPROVAL)
  created_at             DateTime                 @default(now())
  updated_at             DateTime                 @default(now()) @updatedAt
  city                   String?
  state                  String?
  pin_code               String?
  assigned_at            DateTime?
  reminder_enabled       Boolean                  @default(false)
  last_reminder_sent_at  DateTime?
  tracking_code          String                   @unique
  users                  users?                   @relation("UserTickets", fields: [user_id], references: [id], onUpdate: Restrict, map: "fk_ticket_user")
  assigned_technician    users?                   @relation("TechnicianAssignments", fields: [assigned_technician_id], references: [id], onUpdate: Restrict, map: "fk_ticket_assigned_technician")
  otp_challenges         otp_challenges[]
  new_connection_request new_connection_requests?

  @@index([user_id], map: "idx_tickets_user_id")
  @@index([assigned_technician_id, status], map: "idx_tickets_assigned_status")
  @@index([reminder_enabled, status, last_reminder_sent_at], map: "idx_tickets_reminder_due")
  @@index([status, created_at], map: "idx_tickets_status_created")
  @@index([source, created_at], map: "idx_tickets_source_created")
  @@index([reporter_phone], map: "idx_tickets_reporter_phone")
}

model payments {
  id                  String          @id @default(uuid())
  subscription_id     String
  user_id             String
  amount              Decimal
  razorpay_payment_id String?
  razorpay_order_id   String?         @unique(map: "uk_razorpay_order_id")
  status              payments_status @default(pending)
  payment_date        DateTime?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  subscriptions       subscriptions   @relation(fields: [subscription_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "payments_ibfk_1")
  users               users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "payments_ibfk_2")

  @@index([payment_date], map: "idx_payment_date")
  @@index([razorpay_payment_id], map: "idx_razorpay_id")
  @@index([razorpay_order_id], map: "idx_razorpay_order_id")
  @@index([status], map: "idx_payments_status")
  @@index([subscription_id], map: "idx_subscription_id")
  @@index([user_id], map: "idx_payments_user_id")
  @@index([user_id, status], map: "idx_payments_user_status")
}

model plan_variants {
  id                      String                    @id @default(uuid())
  plan_id                 String
  speed_mbps              Int
  duration_months         Int
  price                   Decimal
  created_at              DateTime                  @default(now())
  plans                   plans                     @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "plan_variants_ibfk_1")
  subscriptions           subscriptions[]
  new_connection_requests new_connection_requests[]

  @@unique([plan_id, speed_mbps, duration_months], map: "unique_variant")
  @@index([plan_id], map: "idx_plan_id")
  @@index([speed_mbps, duration_months], map: "idx_speed_duration")
}

model plans {
  id            String          @id @default(uuid())
  name          String          @unique(map: "uk_plans_name")
  description   String?
  created_at    DateTime        @default(now())
  plan_variants plan_variants[]

  @@index([name], map: "idx_name")
}

model subscriptions {
  id              String               @id @default(uuid())
  user_id         String
  plan_variant_id String
  start_date      DateTime
  end_date        DateTime
  status          subscriptions_status @default(active)
  created_at      DateTime             @default(now())
  updated_at      DateTime             @updatedAt
  payments        payments[]
  users           users                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "subscriptions_ibfk_1")
  plan_variants   plan_variants        @relation(fields: [plan_variant_id], references: [id], onUpdate: Restrict, map: "subscriptions_ibfk_2")

  @@index([end_date], map: "idx_end_date")
  @@index([status], map: "idx_subscriptions_status")
  @@index([user_id, status, end_date], map: "idx_user_active")
  @@index([user_id], map: "idx_subscriptions_user_id")
  @@index([user_id, status], map: "idx_subscriptions_user_status")
  @@index([plan_variant_id], map: "plan_variant_id")
}

model otp_challenges {
  id           String          @id @default(uuid())
  user_id      String?
  ticket_id    String?
  purpose      otp_purpose
  target_type  otp_target_type
  target       String
  otp_hash     String
  attempts     Int             @default(0)
  max_attempts Int             @default(5)
  expires_at   DateTime
  consumed_at  DateTime?
  request_ip   String?
  user_agent   String?
  created_at   DateTime        @default(now())
  tickets      tickets?        @relation(fields: [ticket_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_otp_ticket")
  users        users?          @relation(fields: [user_id], references: [id], onUpdate: Restrict, map: "fk_otp_user")

  @@index([target, purpose, expires_at], map: "idx_otp_target_purpose_expires")
  @@index([user_id, purpose], map: "idx_otp_user_purpose")
  @@index([ticket_id, purpose], map: "idx_otp_ticket_purpose")
  @@index([expires_at], map: "idx_otp_expires")
}

model new_connection_requests {
  id                          String                     @id @default(uuid())
  user_id                     String?
  plan_variant_id             String
  ticket_id                   String?                    @unique(map: "uk_new_connection_ticket_id")
  customer_name               String
  customer_email              String
  customer_phone              String
  installation_address        String
  city                        String
  state                       String
  pin_code                    String
  landmark                    String?
  notes                       String?
  amount                      Decimal
  status                      new_connection_status      @default(PENDING_PAYMENT)
  request_source              new_connection_request_source @default(CUSTOMER_CHECKOUT)
  payment_mode                new_connection_payment_mode @default(CASHFREE)
  cashfree_order_id           String?                    @unique(map: "uk_cashfree_order_id")
  cashfree_payment_id         String?
  cashfree_payment_session_id String?
  paid_at                     DateTime?
  reviewed_by_id              String?
  reviewed_at                 DateTime?
  rejection_reason            String?
  admin_notified_at           DateTime?
  customer_notified_at        DateTime?
  created_at                  DateTime                   @default(now())
  updated_at                  DateTime                   @updatedAt
  users                       users?                     @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "new_connection_requests_user_id_fkey")
  reviewed_by                 users?                     @relation("NewConnectionRequestReviewer", fields: [reviewed_by_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "new_connection_requests_reviewed_by_id_fkey")
  plan_variants               plan_variants              @relation(fields: [plan_variant_id], references: [id], onUpdate: Restrict, map: "new_connection_requests_plan_variant_id_fkey")
  tickets                     tickets?                   @relation(fields: [ticket_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "new_connection_requests_ticket_id_fkey")
  document_upload_requests    document_upload_requests[]

  @@index([status, created_at], map: "idx_new_connection_status_created")
  @@index([customer_phone], map: "idx_new_connection_customer_phone")
  @@index([customer_email], map: "idx_new_connection_customer_email")
  @@index([user_id], map: "idx_new_connection_user_id")
  @@index([reviewed_by_id], map: "idx_new_connection_reviewed_by_id")
  @@index([request_source, created_at], map: "idx_new_connection_source_created")
  @@index([plan_variant_id], map: "idx_new_connection_plan_variant_id")
}

model site_notifications {
  id          String   @id @default(uuid())
  title       String
  description String
  expires_at  DateTime
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([expires_at], map: "idx_site_notifications_expires_at")
}

model document_upload_requests {
  id                        String                  @id @default(uuid())
  token                     String                  @unique(map: "uk_document_upload_requests_token")
  new_connection_request_id String
  status                    document_upload_status  @default(PENDING)
  upload_mode               document_upload_mode    @default(CUSTOMER_LINK)
  required_documents        document_type[]         @default([ID_PROOF, ADDRESS_PROOF])
  expires_at                DateTime
  created_by_id             String?
  created_at                DateTime                @default(now())
  updated_at                DateTime                @updatedAt
  new_connection_request    new_connection_requests @relation(fields: [new_connection_request_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "document_upload_requests_new_connection_request_id_fkey")
  created_by                users?                  @relation("DocumentUploadRequestCreator", fields: [created_by_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "document_upload_requests_created_by_id_fkey")
  files                     document_upload_files[]

  @@index([new_connection_request_id], map: "idx_document_upload_requests_connection")
  @@index([created_by_id], map: "idx_document_upload_requests_created_by")
  @@index([status, expires_at], map: "idx_document_upload_requests_status_expires")
}

model document_upload_files {
  id                         String                   @id @default(uuid())
  document_upload_request_id String
  document_type              document_type
  original_file_name         String
  s3_key                     String                   @unique(map: "uk_document_upload_files_s3_key")
  mime_type                  String
  file_size                  Int
  uploaded_by_id             String?
  uploaded_by_type           document_upload_actor
  created_at                 DateTime                 @default(now())
  document_upload_request    document_upload_requests @relation(fields: [document_upload_request_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "document_upload_files_request_id_fkey")
  uploaded_by                users?                   @relation("DocumentUploadFileUploader", fields: [uploaded_by_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "document_upload_files_uploaded_by_id_fkey")

  @@index([document_upload_request_id], map: "idx_document_upload_files_request")
  @@index([document_type], map: "idx_document_upload_files_type")
  @@index([uploaded_by_id], map: "idx_document_upload_files_uploaded_by")
}

enum document_upload_status {
  PENDING
  SUBMITTED
  EXPIRED
  CANCELLED
}

enum document_upload_mode {
  CUSTOMER_LINK
  MANUAL_UPLOAD
}

enum document_type {
  ID_PROOF
  ADDRESS_PROOF
  CUSTOMER_PHOTO
  BUSINESS_PROOF
  OTHER
}

enum document_upload_actor {
  CUSTOMER
  ADMIN
  TECHNICIAN
}

enum new_connection_status {
  PENDING_PAYMENT
  PAYMENT_FAILED
  PAYMENT_DROPPED
  PAID
  UNDER_REVIEW
  ASSIGNED
  INSTALLATION_IN_PROGRESS
  INSTALLED
  ACTIVATED
  REJECTED
  CANCELLED
  REFUNDED
}

enum new_connection_request_source {
  CUSTOMER_CHECKOUT
  ADMIN_CREATED
}

enum new_connection_payment_mode {
  CASHFREE
  CASH
  BANK_TRANSFER
  UPI
  NOT_COLLECTED
}

enum ROLE {
  USER
  ADMIN
  TECHNICIAN
}

enum ticket_issue_type {
  Internet_speed                 @map("Internet speed")
  Downtime_outage                @map("Downtime/outage")
  Billing_error                  @map("Billing error")
  Equipment_fault                @map("Equipment fault")
  New_connection_delay           @map("New connection delay")
  Poor_signal                    @map("Poor signal")
  Not_working_more_than_4_hours  @map("Not working more than 4 hours")
  Not_working_more_than_24_hours @map("Not working more than 24 hours")
  Not_working_more_than_48_hours @map("Not working more than 48 hours")
  Other
}

enum ticket_status {
  PENDING_APPROVAL
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum ticket_source {
  AUTHENTICATED
  GUEST
  ADMIN
}

enum payments_status {
  pending
  success
  failed
}

enum subscriptions_status {
  active
  expired
  cancelled
}

enum users_auth_type {
  PASSWORD
  OTP
}

enum otp_purpose {
  FORGOT_PASSWORD
  ADMIN_LOGIN
  TICKET_RESOLVE
}

enum otp_target_type {
  EMAIL
  PHONE
}
