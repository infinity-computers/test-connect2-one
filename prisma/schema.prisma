generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model users {
  id             String           @id @default(uuid()) @db.VarChar(64)
  name           String           @db.VarChar(100)
  email          String           @unique(map: "uk_users_email") @db.VarChar(150)
  phone          String?          @unique(map: "uk_users_phone") @db.VarChar(20)
  password       String?          @db.VarChar(255)
  role           ROLE             @default(USER)
  auth_type      users_auth_type  @default(PASSWORD)
  complaints     complaints[]
  payments       payments[]
  subscriptions  subscriptions[]
  otp_challenges otp_challenges[]

  @@index([role], map: "idx_users_role")
}

model complaints {
  id                   String                @id @default(uuid()) @db.VarChar(36)
  tracking_code        String                @unique @db.VarChar(16)
  user_id              String?               @db.VarChar(64)
  source               complaints_source     @default(AUTHENTICATED)
  reporter_name        String?               @db.VarChar(100)
  reporter_phone       String?               @db.VarChar(20)
  reporter_email       String?               @db.VarChar(150)
  reporter_address     String?               @db.Text
  city                 String?               @db.VarChar(100)
  state                String?               @db.VarChar(100)
  pin_code             String?               @db.VarChar(20)
  issue_type           complaints_issue_type
  explicit_description String?               @db.Text
  status               complaints_status     @default(OPEN)
  created_at           DateTime              @default(now()) @db.Timestamp(0)
  updated_at           DateTime              @default(now()) @updatedAt @db.Timestamp(0)
  users                users?                @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_complaint_user")
  otp_challenges       otp_challenges[]

  @@index([user_id], map: "idx_complaints_user_id")
  @@index([status, created_at], map: "idx_complaints_status_created")
  @@index([source, created_at], map: "idx_complaints_source_created")
  @@index([reporter_phone], map: "idx_complaints_reporter_phone")
}

model payments {
  id                  String          @id @default(uuid()) @db.VarChar(36)
  subscription_id     String          @db.VarChar(36)
  user_id             String          @db.VarChar(64)
  amount              Decimal         @db.Decimal(10, 2)
  razorpay_payment_id String?         @db.VarChar(100)
  razorpay_order_id   String?         @unique(map: "uk_razorpay_order_id") @db.VarChar(100)
  status              payments_status @default(pending)
  payment_date        DateTime?       @db.DateTime(0)
  created_at          DateTime        @default(now()) @db.Timestamp(0)
  updated_at          DateTime        @updatedAt @db.Timestamp(0)
  subscriptions       subscriptions   @relation(fields: [subscription_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "payments_ibfk_1")
  users               users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "payments_ibfk_2")

  @@index([payment_date], map: "idx_payment_date")
  @@index([razorpay_payment_id], map: "idx_razorpay_id")
  @@index([razorpay_order_id], map: "idx_razorpay_order_id")
  @@index([status], map: "idx_status")
  @@index([subscription_id], map: "idx_subscription_id")
  @@index([user_id], map: "idx_user_id")
  @@index([user_id, status], map: "idx_user_status")
}

model plan_variants {
  id              String          @id @default(uuid()) @db.VarChar(36)
  plan_id         String          @db.VarChar(36)
  speed_mbps      Int
  duration_months Int
  price           Decimal         @db.Decimal(10, 2)
  created_at      DateTime        @default(now()) @db.Timestamp(0)
  plans           plans           @relation(fields: [plan_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "plan_variants_ibfk_1")
  subscriptions   subscriptions[]

  @@unique([plan_id, speed_mbps, duration_months], map: "unique_variant")
  @@index([plan_id], map: "idx_plan_id")
  @@index([speed_mbps, duration_months], map: "idx_speed_duration")
}

model plans {
  id            String          @id @default(uuid()) @db.VarChar(36)
  name          String          @unique(map: "uk_plans_name") @db.VarChar(50)
  description   String?         @db.Text
  created_at    DateTime        @default(now()) @db.Timestamp(0)
  plan_variants plan_variants[]

  @@index([name], map: "idx_name")
}

model subscriptions {
  id              String               @id @default(uuid()) @db.VarChar(36)
  user_id         String               @db.VarChar(64)
  plan_variant_id String               @db.VarChar(36)
  start_date      DateTime             @db.Date
  end_date        DateTime             @db.Date
  status          subscriptions_status @default(active)
  created_at      DateTime             @default(now()) @db.Timestamp(0)
  updated_at      DateTime             @updatedAt @db.Timestamp(0)
  payments        payments[]
  users           users                @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "subscriptions_ibfk_1")
  plan_variants   plan_variants        @relation(fields: [plan_variant_id], references: [id], onUpdate: Restrict, map: "subscriptions_ibfk_2")

  @@index([end_date], map: "idx_end_date")
  @@index([status], map: "idx_status")
  @@index([user_id, status, end_date], map: "idx_user_active")
  @@index([user_id], map: "idx_user_id")
  @@index([user_id, status], map: "idx_user_status")
  @@index([plan_variant_id], map: "plan_variant_id")
}

model otp_challenges {
  id           String          @id @default(uuid()) @db.VarChar(36)
  user_id      String?         @db.VarChar(64)
  complaint_id String?         @db.VarChar(36)
  purpose      otp_purpose
  target_type  otp_target_type
  target       String          @db.VarChar(191)
  otp_hash     String          @db.VarChar(255)
  attempts     Int             @default(0)
  max_attempts Int             @default(5)
  expires_at   DateTime        @db.Timestamp(0)
  consumed_at  DateTime?       @db.Timestamp(0)
  request_ip   String?         @db.VarChar(45)
  user_agent   String?         @db.VarChar(255)
  created_at   DateTime        @default(now()) @db.Timestamp(0)
  users        users?          @relation(fields: [user_id], references: [id], onDelete: SetNull, onUpdate: Restrict, map: "fk_otp_user")
  complaints   complaints?     @relation(fields: [complaint_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_otp_complaint")

  @@index([target, purpose, expires_at], map: "idx_otp_target_purpose_expires")
  @@index([user_id, purpose], map: "idx_otp_user_purpose")
  @@index([complaint_id, purpose], map: "idx_otp_complaint_purpose")
  @@index([expires_at], map: "idx_otp_expires")
}

enum ROLE {
  USER
  ADMIN
  TECHNICIAN
}

enum complaints_issue_type {
  Internet_speed                 @map("Internet speed")
  Downtime_outage                @map("Downtime/outage")
  Billing_error                  @map("Billing error")
  Equipment_fault                @map("Equipment fault")
  New_connection_delay           @map("New connection delay")
  Poor_signal                    @map("Poor signal")
  Not_working_more_than_4_hours  @map("Not working more than 4 hours")
  Not_working_more_than_24_hours @map("Not working more than 24 hours")
  Not_working_more_than_48_hours @map("Not working more than 48 hours")
  Other
}

enum complaints_status {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum complaints_source {
  AUTHENTICATED
  GUEST
}

enum payments_status {
  pending
  success
  failed
}

enum subscriptions_status {
  active
  expired
  cancelled
}

enum users_auth_type {
  PASSWORD
  OTP
}

enum otp_purpose {
  FORGOT_PASSWORD
  ADMIN_LOGIN
  COMPLAINT_RESOLVE
}

enum otp_target_type {
  EMAIL
  PHONE
}
